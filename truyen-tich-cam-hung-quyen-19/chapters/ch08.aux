\@writefile{toc}{\contentsline {section}{\numberline {8.1}Em không bắt buộc phải trả lời ngay; em có quyền nghĩ trước.}{57}{}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {8.2}Im lặng là khoảng trống để ý tưởng lớn lên.}{58}{}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {8.3}Câu hỏi hay thường được theo sau bởi im lặng — vì mọi người đang nghĩ.}{58}{}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {8.4}Người biết im lặng đúng lúc thường là người nói có sức nặng.}{59}{}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {8.5}Học không chỉ là nghe và trả lời — học còn là im lặng và suy nghĩ.}{60}{}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {8.6}Im lặng không phải từ chối tham gia — mà là tham gia bằng cách nghĩ.}{61}{}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {8.7}Thầy chấp nhận im lặng — vì thầy biết suy nghĩ cần thời gian.}{61}{}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {8.8}Điều em nghĩ trong im lặng có thể quan trọng hơn điều em nói trong ồn ào.}{62}{}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {8.9}Lớp học tốt là nơi im lặng được tôn trọng.}{63}{}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {8.10}Suy nghĩ sâu thường bắt đầu từ một khoảnh khắc im lặng.}{63}{}\protected@file@percent }
